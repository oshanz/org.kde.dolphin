                    "sha256": "28810d0b4407d0ac752f9420ecd843af2f5568751fc1c70d114620f0596fdeec",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8761,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/plasma/$version/kde-cli-tools-$version.tar.xz"
                    }
                }
            ]
        },
        {
